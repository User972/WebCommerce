@model SirJoshua.Web.ViewModels.HomeViewModel
@using System.Globalization
@{
    Layout = null;
    var inv = CultureInfo.InvariantCulture;
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var f = SiteContent.Flagship;
    var ebook = Model.Flagship;
    var inCatalog = ebook is not null;
    var desc = "Learn IELTS Writing Task 1 and Task 2 structures, Band 7+ vocabulary, high-scoring sample responses, common mistakes, and exam-day strategies with The Band 7+ Formula.";
}
<!doctype html>
<html lang="en">
<head>
<script>(function(){try{var t=localStorage.getItem('check-theme');if(t!=='light'&&t!=='dark'){t=window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';}document.documentElement.setAttribute('data-theme',t);}catch(e){document.documentElement.setAttribute('data-theme','light');}})();</script>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>IELTS Writing Mastery: The Band 7+ Formula</title>
<meta name="description" content="@desc" />
<link rel="canonical" href="@baseUrl@f.Route" />
<meta property="og:type" content="product" />
<meta property="og:site_name" content="@SiteContent.FooterBrand" />
<meta property="og:title" content="IELTS Writing Mastery: The Band 7+ Formula" />
<meta property="og:description" content="@desc" />
<meta property="og:url" content="@baseUrl@f.Route" />
<meta property="og:image" content="@baseUrl/uploads/sir-joshua-logo.png" />
<script src="https://cdn.jsdelivr.net/npm/tailwindcss-cdn@@3.4.10/tailwindcss.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@@9..144,400;9..144,500;9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@@400;500;600;700&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/b7plus.css" asp-append-version="true" />
<script>
  tailwind.config = {
    theme: { extend: {
      colors: {
        ink:'rgb(var(--c-ink) / <alpha-value>)', surface:'rgb(var(--c-surface) / <alpha-value>)',
        card:'rgb(var(--c-card) / <alpha-value>)', paper:'rgb(var(--c-paper) / <alpha-value>)',
        parch:'rgb(var(--c-parch) / <alpha-value>)', line:'rgb(var(--c-line) / <alpha-value>)',
        teal:{50:'#E8F0EF',100:'#C9DAD8',500:'#1A5C5C',600:'#0F3D3E',700:'#0A2C2D',800:'#06201F'},
        terra:{400:'#E89679',500:'#D97757',600:'#C0603F',700:'#9E4A2D'}, gold:'#C8A24B',
      },
      fontFamily: {
        serif:['Fraunces','ui-serif','Georgia','serif'],
        sans:['"Plus Jakarta Sans"','ui-sans-serif','system-ui','sans-serif'],
        mono:['"JetBrains Mono"','ui-monospace','monospace'],
      },
    }}
  }
</script>
<script type="application/ld+json">@Html.Raw(StructuredData.HomeJsonLd(baseUrl))</script>
@if (Model.PayPalEnabled)
{
    <script src="https://www.paypal.com/sdk/js?client-id=@Model.PayPalClientId&currency=@Model.PayPalCurrency&intent=capture&components=buttons&disable-funding=credit"></script>
}
<script>
  window.SJ_CONFIG = { paypalEnabled: @(Model.PayPalEnabled ? "true" : "false"), currency: '@Model.PayPalCurrency', idrPerUsd: @Model.IdrPerUsd.ToString("0.####", inv), promoCode: '@Model.PromoCode' };
  window.B7_CONFIG = { payments: [@Html.Raw(string.Join(",", SiteContent.PaymentMethods.Select(p => $"{{id:'{p.Id}',name:'{p.Name}'}}")))] };
</script>
</head>
<body class="antialiased" id="top">
@Html.AntiForgeryToken()
<a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:top-3 focus:left-3 focus:px-4 focus:py-2 focus:rounded-full focus:bg-teal-700 focus:text-parch focus:font-semibold">Skip to content</a>

<!-- ============== HEADER ============== -->
<header class="sticky top-0 z-40 bg-surface/85 backdrop-blur border-b hairline">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 h-[68px] flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <img src="/uploads/sir-joshua-logo.png" alt="Sir Joshua Academy logo" class="h-10 w-auto object-contain">
      <span class="leading-none">
        <span class="block font-display text-[18px] font-semibold tracking-tight">IELTS Band 7 Plus<span class="text-terra-500 align-super text-[10px]">™</span></span>
        <span class="block text-[11px] text-ink/55 mt-0.5">by Sir Joshua Academy</span>
      </span>
    </a>
    <div class="flex items-center gap-2 md:gap-3">
      <a href="/" class="inline-flex items-center gap-1 text-[14px] text-ink/70 hover:text-ink" aria-label="Back to home">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <span class="hidden sm:inline underline-hover">Back to home</span>
      </a>
      <button id="themeToggle" type="button" aria-label="Switch light / dark theme" class="w-10 h-10 rounded-full border hairline bg-card flex items-center justify-center text-ink/70 hover:text-ink hover:border-teal-600 transition">
        <svg class="icon-moon w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2.2M12 19.8V22M4.6 4.6l1.6 1.6M17.8 17.8l1.6 1.6M2 12h2.2M19.8 12H22M4.6 19.4l1.6-1.6M17.8 6.2l1.6-1.6"/></svg>
      </button>
      <button id="cartBtn" type="button" aria-label="Open cart" class="relative w-10 h-10 rounded-full border hairline bg-card flex items-center justify-center text-ink/70 hover:text-ink hover:border-teal-600 transition">
        <svg class="w-[19px] h-[19px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h2l.5 2.5M6 6h14.5l-1.6 8H8.1L6 6z"/><path d="M5.5 5.5 8.1 14"/><circle cx="9.5" cy="19" r="1.4"/><circle cx="17" cy="19" r="1.4"/></svg>
        <span id="cartBadge" class="cart-badge hide">0</span>
      </button>
      <a href="#buy" class="inline-flex px-4 py-2.5 rounded-full bg-terra-500 text-white text-[14px] font-semibold hover:bg-terra-600 transition whitespace-nowrap">Get it now</a>
    </div>
  </div>
</header>

<main id="main">
<!-- ============== HERO ============== -->
<section class="relative overflow-hidden" aria-labelledby="p-hero">
  <div class="absolute inset-0 -z-10"><div class="absolute inset-0 bg-surface"></div><div class="absolute -top-40 -left-40 w-[640px] h-[640px] rounded-full bg-teal-50/60 blur-2xl"></div><div class="absolute inset-0 grain opacity-60"></div></div>
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 pt-10 md:pt-16 pb-14 md:pb-20 grid lg:grid-cols-12 gap-10 items-center">
    <div class="lg:col-span-7">
      <nav class="text-[12.5px] text-ink/55 mb-5" aria-label="Breadcrumb"><a href="/" class="hover:text-ink">Home</a> <span class="px-1">/</span> <span class="text-ink/70">The Band 7+ Formula</span></nav>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-50 text-teal-700 text-[12.5px] font-medium tracking-wide"><span class="w-1.5 h-1.5 rounded-full bg-terra-500"></span>Flagship product · IELTS Writing</div>
      <h1 id="p-hero" class="mt-5 font-display font-medium leading-[1.0] text-ink text-[34px] sm:text-[46px] lg:text-[56px]">@f.Name</h1>
      <p class="mt-5 text-[17px] md:text-[18px] leading-relaxed text-ink/70 max-w-[600px]">@f.Description</p>
      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a href="#buy" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full bg-teal-600 text-parch font-semibold hover:bg-teal-700 transition">Get the Band 7+ Formula</a>
        <div class="flex items-end gap-2">
          <span class="price-launch text-[26px] text-ink leading-none">@Money.Rp(f.LaunchPriceIdr)</span>
          <span class="text-[14px] text-ink/45 price-strike mb-0.5">@Money.Rp(f.RegularPriceIdr)</span>
        </div>
      </div>
    </div>
    <div class="lg:col-span-5">
      <div class="w-[200px] mx-auto"><div class="ebook-cover cover-teal"><span class="spine"></span><span class="frame"></span><div class="inner"><span class="imprint">IELTS Band 7 Plus</span><div class="flex-1"></div><div class="rule"></div><span class="series">IELTS · Writing</span><div class="title">The Band 7+ Formula</div><span class="by">Sir Joshua Academy</span></div></div></div>
    </div>
  </div>
</section>

<!-- ============== WHO THIS IS FOR ============== -->
<section class="py-16 md:py-24 bg-paper/40 border-y hairline" aria-labelledby="who-h">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— Who this is for</div>
    <h2 id="who-h" class="mt-3 font-display text-[30px] md:text-[40px] font-medium leading-[1.05]">Built for candidates aiming higher in Writing</h2>
    <div class="mt-8 grid sm:grid-cols-2 gap-4">
@foreach (var w in f.WhoFor)
{
      <div class="flex items-start gap-3 bg-card border hairline rounded-2xl p-5"><svg class="w-5 h-5 mt-0.5 text-teal-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg><span class="text-[15px] text-ink/80">@w</span></div>
}
    </div>
  </div>
</section>

<!-- ============== WHAT YOU'LL LEARN ============== -->
<section class="py-16 md:py-24" aria-labelledby="learn-h">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— What you’ll learn</div>
    <h2 id="learn-h" class="mt-3 font-display text-[30px] md:text-[40px] font-medium leading-[1.05]">A structured method, not scattered tips</h2>
    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
@foreach (var o in f.LearningOutcomes)
{
      <div class="bg-card border hairline rounded-2xl p-6 lift"><svg class="w-6 h-6 text-teal-600 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20l9-5-9-5-9 5 9 5z"/><path d="M12 12l9-5-9-5-9 5 9 5z" opacity=".5"/></svg><p class="text-[15px] text-ink/80 leading-snug">@o</p></div>
}
    </div>
  </div>
</section>

<!-- ============== PROBLEMS IT SOLVES ============== -->
<section class="py-16 md:py-24 bg-paper/40 border-y hairline" aria-labelledby="prob-h">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 grid md:grid-cols-12 gap-10">
    <div class="md:col-span-5">
      <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— Problems it solves</div>
      <h2 id="prob-h" class="mt-3 font-display text-[30px] md:text-[40px] font-medium leading-[1.05]">If any of this sounds familiar, this is for you</h2>
    </div>
    <ul class="md:col-span-7 space-y-3 self-center">
@foreach (var p in f.ProblemsSolved)
{
      <li class="flex items-start gap-3 text-[15.5px] text-ink/80"><svg class="w-5 h-5 mt-0.5 text-terra-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg><span>@p</span></li>
}
    </ul>
  </div>
</section>

<!-- ============== WHAT'S INCLUDED + PRICE + BUY ============== -->
<section id="buy" class="py-16 md:py-24" aria-labelledby="buy-h">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 grid lg:grid-cols-12 gap-10 items-start">
    <div class="lg:col-span-7">
      <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— What’s included</div>
      <h2 id="buy-h" class="mt-3 font-display text-[30px] md:text-[40px] font-medium leading-[1.05]">Everything in the guide</h2>
      <div class="mt-8 grid sm:grid-cols-2 gap-x-6 gap-y-3">
@foreach (var inc in f.Inclusions)
{
        <div class="flex items-start gap-2.5 text-[15px] text-ink/80"><svg class="w-5 h-5 mt-0.5 text-teal-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg><span>@inc</span></div>
}
      </div>
    </div>

    <div class="lg:col-span-5">
@if (inCatalog)
{
      <div class="relative bg-card border hairline rounded-[20px] p-6 md:p-7 shadow-[0_30px_80px_-40px_rgba(15,61,62,.35)]"
           data-product data-id="@ebook!.Id" data-title="@ebook.Title" data-author="@ebook.Author" data-price="@ebook.PriceIdr" data-cat="@ebook.Category" data-cover="@ebook.Cover">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-terra-50 text-terra-700 text-[11.5px] font-semibold" style="background:#FBE7DD">Launch offer</div>
        <div class="mt-4 flex items-end gap-3"><span class="price-launch text-[42px] text-ink leading-none">@Money.Rp(f.LaunchPriceIdr)</span><span class="text-[16px] text-ink/45 price-strike mb-1.5">@Money.Rp(f.RegularPriceIdr)</span></div>
        <p class="mt-1.5 text-[13px] text-terra-600 font-semibold">Save @Money.Rp(f.SavingsIdr) at the launch price.</p>
        <div class="mt-6 flex flex-col gap-2.5">
          <button type="button" class="add-cart inline-flex items-center justify-center gap-2 w-full px-6 py-3.5 rounded-full bg-terra-500 text-white font-semibold hover:bg-terra-600 transition shadow-[0_10px_24px_-12px_rgba(217,119,87,.85)]" data-id="@ebook.Id"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg>Get the Band 7+ Formula</button>
          <button type="button" data-enquiry="product" data-interest="Band 7+ Formula" data-item="@f.Id" class="btn-ghost w-full">Request payment link</button>
        </div>
        <p class="mt-3 text-center text-[11.5px] text-ink/50">Instant download after payment · delivered to your email.</p>
        <div class="mt-5 pt-5 border-t hairline"><div class="font-mono uppercase tracking-[0.16em] text-[10px] text-ink/45 mb-2.5">Pay with</div><div class="flex flex-wrap gap-1.5">
@foreach (var pm in SiteContent.PaymentMethods)
{
          <span class="px-2.5 py-1 rounded-md border hairline bg-surface text-[11.5px] font-semibold text-ink/70">@pm.Name</span>
}
        </div></div>
      </div>
}
else
{
      <div class="relative bg-card border hairline rounded-[20px] p-6 md:p-7 shadow-[0_30px_80px_-40px_rgba(15,61,62,.35)]">
        <div class="flex items-end gap-3"><span class="price-launch text-[42px] text-ink leading-none">@Money.Rp(f.LaunchPriceIdr)</span><span class="text-[16px] text-ink/45 price-strike mb-1.5">@Money.Rp(f.RegularPriceIdr)</span></div>
        <button type="button" data-enquiry="product" data-interest="Band 7+ Formula" data-item="@f.Id" class="btn-primary w-full mt-6">Get the Band 7+ Formula</button>
        <p class="mt-3 text-center text-[11.5px] text-ink/50">We’ll send payment &amp; access instructions.</p>
      </div>
}
    </div>
  </div>
</section>

<!-- ============== FAQ ============== -->
<section class="py-16 md:py-24 bg-paper/40 border-y hairline" aria-labelledby="pfaq-h">
  <div class="max-w-[1080px] mx-auto px-5 md:px-8">
    <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— FAQ</div>
    <h2 id="pfaq-h" class="mt-3 font-display text-[30px] md:text-[40px] font-medium leading-[1.05]">Product questions</h2>
    <div class="mt-8 divide-y hairline border-y hairline">
@{ var i = 0; }
@foreach (var q in f.Faq)
{
      <details class="group py-5"@(i == 0 ? " open" : "")>
        <summary class="flex items-center justify-between gap-6"><span class="font-display text-[19px] md:text-[21px] font-semibold leading-snug pr-6">@q.Question</span><span class="faq-icon shrink-0 w-9 h-9 rounded-full border hairline flex items-center justify-center text-terra-600 text-xl leading-none">+</span></summary>
        <p class="mt-3 text-[15.5px] text-ink/70 leading-relaxed max-w-[760px]">@q.Answer</p>
      </details>
      i++;
}
    </div>
  </div>
</section>

<!-- ============== FINAL CTA ============== -->
<section class="py-14 md:py-20 bg-teal-700 text-parch relative overflow-hidden" aria-labelledby="pcta-h">
  <div class="absolute -top-20 -right-20 w-[400px] h-[400px] rounded-full bg-terra-500/20 blur-3xl"></div>
  <div class="absolute inset-0 grain opacity-15"></div>
  <div class="max-w-[1080px] mx-auto px-5 md:px-8 relative text-center">
    <h2 id="pcta-h" class="font-display text-[30px] md:text-[44px] font-medium leading-[1.05]">Start writing better responses today</h2>
    <p class="mt-4 text-[16px] text-parch/75 max-w-[620px] mx-auto">Get the structured method designed around what IELTS examiners reward — and prepare with a clear plan.</p>
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a href="#buy" class="px-6 py-3.5 rounded-full bg-terra-500 text-white font-semibold hover:bg-terra-600 transition">Get the Band 7+ Formula</a>
      <a href="/#free-checklist" class="px-6 py-3.5 rounded-full border border-parch/25 text-parch font-semibold hover:bg-parch/10 transition">Download Free Checklist</a>
    </div>
  </div>
</section>
</main>

<!-- ============== FOOTER ============== -->
<footer class="bg-teal-800 text-parch/70">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 py-10 flex flex-wrap items-center justify-between gap-4 text-[13px]">
    <div>© 2026 @SiteContent.FooterBrand. All rights reserved.</div>
    <div class="flex items-center gap-5">
      <a href="/" class="hover:text-parch">Home</a>
      <a href="/#services" class="hover:text-parch">Services</a>
      <a href="/#contact" class="hover:text-parch">Contact</a>
    </div>
  </div>
</footer>

@await Html.PartialAsync("_CartDrawer")
@await Html.PartialAsync("_EnquiryModal")

<script src="~/js/funnel.js" asp-append-version="true"></script>
<script src="~/js/forms.js" asp-append-version="true"></script>
</body>
</html>
