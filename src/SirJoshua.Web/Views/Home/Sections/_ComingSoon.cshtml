@model SirJoshua.Web.ViewModels.HomeViewModel
<!-- ============== COMING SOON SERIES ============== -->
<section id="coming-soon" class="py-20 md:py-28 bg-paper/40 border-y hairline" aria-labelledby="soon-heading">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="max-w-[680px]">
      <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— Coming soon</div>
      <h2 id="soon-heading" class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02]">Coming Soon: Complete IELTS Mastery Series</h2>
      <p class="mt-4 text-[16.5px] text-ink/70 leading-relaxed">More structured guides are on the way. Join a waitlist and we’ll let you know the moment each one is ready.</p>
    </div>

    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
@foreach (var p in SiteContent.ComingSoon)
{
      <div class="bg-card border hairline rounded-2xl p-6 flex flex-col">
        <span class="soon-badge">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          Coming soon
        </span>
        <h3 class="font-display text-[19px] font-semibold mt-3">@p.Name</h3>
        <p class="text-[13.5px] text-ink/60 mt-1.5">@p.Benefit</p>
        <div class="mt-auto pt-4">
          <button type="button" data-enquiry="waitlist" data-interest="@p.Name" data-item="@p.Name" class="btn-ghost w-full text-[14px]">Join Waitlist</button>
        </div>
      </div>
}
    </div>
  </div>
</section>
