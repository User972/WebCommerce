@model SirJoshua.Web.ViewModels.HomeViewModel
<!-- ============== CONTACT ============== -->
<section id="contact" class="py-20 md:py-28 bg-paper/40 border-y hairline" aria-labelledby="contact-heading">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="grid md:grid-cols-12 gap-10">
      <!-- Left: intro + contact options -->
      <div class="md:col-span-5">
        <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— Contact</div>
        <h2 id="contact-heading" class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02]">Get in touch</h2>
        <p class="mt-4 text-[16.5px] text-ink/70 leading-relaxed max-w-[460px]">
          Have a question about a product, a service, or your IELTS preparation? Send us a message and we’ll get back to you.
        </p>

        <div class="mt-8 space-y-3">
          <!-- WhatsApp -->
          <a href="https://wa.me/@SiteContent.WhatsAppNumber" target="_blank" rel="noopener"
             class="group flex items-center gap-4 bg-card border hairline rounded-2xl p-4 lift">
            <span class="w-11 h-11 shrink-0 rounded-xl bg-teal-50 text-teal-700 flex items-center justify-center">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            </span>
            <span class="min-w-0">
              <span class="block font-mono uppercase tracking-[0.16em] text-[10.5px] text-terra-600">WhatsApp</span>
              <span class="block mt-0.5 text-[15px] font-semibold text-ink underline-hover">Message us on WhatsApp</span>
            </span>
            <svg class="w-4 h-4 ml-auto text-ink/40 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>

          <!-- Email -->
          <a href="mailto:@SiteContent.ContactEmail"
             class="group flex items-center gap-4 bg-card border hairline rounded-2xl p-4 lift">
            <span class="w-11 h-11 shrink-0 rounded-xl bg-teal-50 text-teal-700 flex items-center justify-center">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            </span>
            <span class="min-w-0">
              <span class="block font-mono uppercase tracking-[0.16em] text-[10.5px] text-terra-600">Email</span>
              <span class="block mt-0.5 text-[15px] font-semibold text-ink underline-hover break-all">@SiteContent.ContactEmail</span>
            </span>
            <svg class="w-4 h-4 ml-auto text-ink/40 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: enquiry form card -->
      <div class="md:col-span-7">
        <div class="bg-card border hairline rounded-[20px] p-6 md:p-7 shadow-[0_30px_80px_-40px_rgba(15,61,62,.35)]">
          <form data-enquiry-form="Contact" novalidate>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="contact-fullname" class="field-label">Name</label>
                <input id="contact-fullname" name="FullName" type="text" class="field-input" autocomplete="name" required>
              </div>
              <div>
                <label for="contact-email" class="field-label">Email</label>
                <input id="contact-email" name="Email" type="email" class="field-input" autocomplete="email" required>
              </div>
              <div>
                <label for="contact-whatsapp" class="field-label">WhatsApp <span class="text-ink/45 font-normal">(optional)</span></label>
                <input id="contact-whatsapp" name="WhatsApp" type="tel" class="field-input" autocomplete="tel">
              </div>
              <div>
                <label for="contact-interest" class="field-label">Interest</label>
                <select id="contact-interest" name="InterestType" class="field-select" required>
                  <option value="" selected disabled>Select…</option>
@foreach (var i in SiteContent.ContactInterests)
{
                  <option>@i</option>
}
                </select>
              </div>
              <div class="sm:col-span-2">
                <label for="contact-message" class="field-label">Message</label>
                <textarea id="contact-message" name="Message" class="field-textarea" rows="4" required></textarea>
              </div>
            </div>

            <div class="honeypot">
              <label>Leave empty<input type="text" name="Website" tabindex="-1" autocomplete="off"></label>
            </div>

            <button type="submit" class="btn-primary w-full mt-5">Send enquiry</button>
            <p class="mt-3 text-center text-[11.5px] text-ink/50">We typically reply within one business day.</p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
