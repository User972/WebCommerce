@model SirJoshua.Web.ViewModels.HomeViewModel
<!-- ============== SERVICES ============== -->
<section id="services" class="py-20 md:py-28" aria-labelledby="services-heading">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="max-w-[760px]">
      <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— Services</div>
      <h2 id="services-heading" class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02]">Personalized IELTS support when you need expert guidance</h2>
      <p class="mt-4 text-[16.5px] text-ink/70 leading-relaxed">
        Choose focused support for writing, speaking, or your overall IELTS preparation strategy. Each service is
        designed to help you understand your current level, identify improvement areas, and prepare with a clearer plan.
      </p>
    </div>

    <div class="mt-12 grid md:grid-cols-2 gap-5">
@foreach (var s in SiteContent.Services)
{
      <div class="bg-card border hairline rounded-2xl p-7 lift flex flex-col relative">
@if (s.Badge != null)
{
        <span class="absolute top-5 right-5 inline-flex items-center px-3 py-1 rounded-full bg-terra-50 text-terra-700 text-[11px] font-semibold tracking-wide" style="background:#FBE7DD">@s.Badge</span>
}
        <h3 class="font-display text-[24px] font-semibold leading-tight pr-24">@s.Name</h3>
        <div class="mt-3 flex items-baseline gap-2">
          <span class="price-launch text-[28px] text-ink leading-none">@Money.Rp(s.PriceIdr)</span>
        </div>

        <div class="mt-6">
          <div class="font-mono uppercase tracking-[0.16em] text-[10.5px] text-ink/45 mb-3">What’s included</div>
          <ul class="space-y-2.5 text-[14px] text-ink/80">
@foreach (var inc in s.Includes)
{
            <li class="flex items-start gap-2.5">
              <svg class="w-[18px] h-[18px] mt-0.5 text-teal-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
              <span>@inc</span>
            </li>
}
          </ul>
        </div>

        <p class="mt-5 text-[13.5px] text-ink/60 leading-relaxed">@s.Purpose</p>

        <div class="mt-auto pt-6">
          <button type="button" data-enquiry="@s.FormType" data-interest="@s.Name" data-item="@s.Id" class="btn-primary w-full">@s.CtaLabel</button>
        </div>
      </div>
}
    </div>

    <p class="mt-8 text-center text-[13.5px] text-ink/55 max-w-[640px] mx-auto">
      Submit the short form and we’ll confirm next steps and send secure payment instructions. We never collect card
      details on this site.
    </p>
  </div>
</section>
