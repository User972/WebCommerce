@model SirJoshua.Web.ViewModels.HomeViewModel
<!-- ============== ABOUT SIR JOSHUA ============== -->
<section id="about" class="py-20 md:py-28" aria-labelledby="about-heading">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="grid md:grid-cols-12 gap-10 items-start">
      <!-- Left: authority copy -->
      <div class="md:col-span-7">
        <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— About Sir Joshua</div>
        <h2 id="about-heading" class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02]">About Sir Joshua</h2>

        <div class="mt-6 space-y-5 text-[16.5px] text-ink/70 leading-relaxed max-w-[640px]">
          <p>
            The teaching here is built on one idea: IELTS preparation should be clear, practical and
            structured. Rather than scattered tips, the focus is on a step-by-step method that shows you
            exactly what high-scoring responses look like — and how to build them yourself.
          </p>
          <p>
            That approach is grounded in what examiners actually reward. Effort goes into the things that
            move a band score — clear task response, organisation, range and accuracy — with most attention
            on <span class="text-ink/90 font-medium">Writing</span>,
            <span class="text-ink/90 font-medium">Speaking</span> and overall
            <span class="text-ink/90 font-medium">exam strategy</span>, where candidates most often get stuck.
          </p>
          <p>
            The goal is simple: help learners understand precisely what to improve next.
            <span class="text-ink/90 font-medium">@SiteContent.ParentBrand</span> is the parent brand, and
            <span class="text-ink/90 font-medium">@SiteContent.BrandTm</span> is its flagship IELTS preparation
            offer — practical, structured guidance designed to help you prepare with confidence.
          </p>
        </div>
      </div>

      <!-- Right: focus card -->
      <div class="md:col-span-5">
        <div class="bg-card border hairline rounded-2xl p-7 lift">
          <h3 class="font-display text-[22px] font-semibold leading-tight">What we focus on</h3>
          <ul class="mt-5 space-y-3.5 text-[14.5px] text-ink/80">
@foreach (var point in new[] {
    "Understanding what IELTS examiners reward",
    "Structured Writing Task 1 & 2 method",
    "Speaking fluency and confidence",
    "A clear, personalized study plan" })
{
            <li class="flex items-start gap-2.5">
              <svg class="w-5 h-5 mt-0.5 text-teal-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
              <span>@point</span>
            </li>
}
          </ul>

          <div class="mt-7 pt-6 border-t hairline">
            <button type="button" data-enquiry="strategy-consultation" data-interest="Strategy Consultation" data-item="strategy-consultation" class="btn-primary w-full">
              Book a Strategy Consultation
            </button>
            <a href="#formula" class="mt-4 inline-flex items-center gap-1 text-teal-700 font-semibold text-[14px] hover:gap-2 transition-all">
              Explore the Band 7+ Formula →
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
