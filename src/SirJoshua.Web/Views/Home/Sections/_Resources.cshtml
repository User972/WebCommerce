@model SirJoshua.Web.ViewModels.HomeViewModel
<!-- ============== RESOURCES — SECONDARY PRACTICE LIBRARY ============== -->
<section id="resources" class="py-20 md:py-28" aria-labelledby="resources-heading">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <!-- Heading -->
    <div class="max-w-[680px]">
      <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— More IELTS practice resources</div>
      <h2 id="resources-heading" class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02]">Supporting guides to build your skills</h2>
      <p class="mt-4 text-[16.5px] text-ink/70 leading-relaxed">
        Practical guides delivered to your email in PDF. A simple way to keep practicing between sessions.
      </p>
    </div>

    <!-- Filter chips -->
    <div id="ebookFilters" class="mt-8 flex flex-wrap gap-2" role="group" aria-label="Filter resources by category">
      <button type="button" data-filter="all" class="chip inline-flex items-center px-4 py-2 rounded-full border bg-teal-600 text-parch border-teal-600 text-[13px] font-semibold">All</button>
      <button type="button" data-filter="IELTS" class="chip inline-flex items-center px-4 py-2 rounded-full border bg-card hairline text-ink/70 text-[13px] font-semibold">IELTS</button>
      <button type="button" data-filter="General" class="chip inline-flex items-center px-4 py-2 rounded-full border bg-card hairline text-ink/70 text-[13px] font-semibold">General</button>
      <button type="button" data-filter="Bundle" class="chip inline-flex items-center px-4 py-2 rounded-full border bg-card hairline text-ink/70 text-[13px] font-semibold">Bundle</button>
    </div>

    <!-- Resource grid -->
    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
@foreach (var e in Model.Ebooks.Where(x => !x.IsBundle))
{
      <article class="ebook-card lift bg-card border hairline rounded-2xl p-4 flex flex-col" data-product data-id="@e.Id" data-title="@e.Title" data-author="@e.Author" data-price="@e.PriceIdr" data-cat="@e.Category" data-cover="@e.Cover">
        <div class="relative">
@if (e.Badge == "Best seller")
{
          <span class="absolute top-2 right-2 z-10 inline-flex items-center px-2.5 py-1 rounded-full bg-terra-500 text-white text-[10.5px] font-semibold tracking-wide shadow-sm">Best seller</span>
}
else if (e.Badge == "New")
{
          <span class="absolute top-2 right-2 z-10 inline-flex items-center px-2.5 py-1 rounded-full bg-emerald-500 text-white text-[10.5px] font-semibold tracking-wide shadow-sm">New</span>
}
          <div class="ebook-cover cover-@e.Cover"><span class="spine"></span><span class="frame"></span><div class="inner"><span class="imprint">IELTS Band 7 Plus</span><div class="flex-1"></div><div class="rule"></div><span class="series">@e.Series</span><div class="title">@e.Title</div><span class="by">@e.Author</span></div></div>
        </div>

        <div class="mt-4 flex items-center gap-2 flex-wrap">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-teal-50 text-teal-700 text-[11.5px] font-semibold">@e.Category</span>
          <span class="text-[11.5px] text-ink/50">@e.Meta</span>
        </div>

        <h3 class="mt-3 font-display text-[18px] font-semibold leading-snug">@e.Title</h3>
        <p class="mt-1.5 text-[13.5px] text-ink/65 leading-relaxed">@e.Description</p>

        <div class="mt-auto pt-4 flex items-center justify-between">
          <div class="font-display text-[21px] font-semibold">@Money.Rp(e.PriceIdr)</div>
          <button class="add-cart inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-teal-600 text-parch text-[13px] font-semibold hover:bg-teal-700 transition" data-id="@e.Id">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg>Add
          </button>
        </div>
      </article>
}
    </div>

    <p id="ebookEmpty" class="hidden text-center text-ink/55 py-14 text-[15px]">No resources in this category yet.</p>

    <!-- Bundle banner -->
@{ var bundle = Model.Ebooks.FirstOrDefault(x => x.IsBundle); }
@if (bundle != null)
{
    <div class="mt-6 relative overflow-hidden rounded-2xl bg-teal-700 text-parch p-6 md:p-8 shadow-[0_30px_80px_-44px_rgba(15,61,62,.55)]"
         data-product data-id="@bundle.Id" data-title="@bundle.Title" data-author="@bundle.Author" data-price="@bundle.PriceIdr" data-cat="@bundle.Category" data-cover="@bundle.Cover">
      <div class="absolute -top-16 -right-12 w-[280px] h-[280px] rounded-full bg-terra-400/20 blur-2xl pointer-events-none"></div>
      <div class="relative grid md:grid-cols-12 gap-6 items-center">
        <div class="md:col-span-7">
          <div class="font-mono uppercase tracking-[0.16em] text-[10.5px] text-parch/70">— Bundle</div>
          <h3 class="mt-2 font-display text-[24px] md:text-[30px] font-semibold leading-tight">@bundle.Title</h3>
          <p class="mt-2 text-[14.5px] text-parch/80 leading-relaxed max-w-[520px]">@bundle.Description</p>
        </div>
        <div class="md:col-span-5 md:text-right">
          <div class="flex items-end gap-3 md:justify-end">
@if (bundle.CompareAtIdr.HasValue)
{
            <span class="text-[15px] text-parch/55 price-strike mb-1.5">@Money.Rp(bundle.CompareAtIdr.Value)</span>
}
            <span class="price-launch text-[40px] leading-none">@Money.Rp(bundle.PriceIdr)</span>
          </div>
          <button class="add-cart mt-5 inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-terra-500 text-white font-semibold hover:bg-terra-600 transition shadow-[0_10px_24px_-12px_rgba(217,119,87,.85)]" data-id="@bundle.Id">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg>Add bundle
          </button>
        </div>
      </div>
    </div>
}
  </div>
</section>
