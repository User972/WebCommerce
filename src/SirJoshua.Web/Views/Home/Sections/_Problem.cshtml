@model SirJoshua.Web.ViewModels.HomeViewModel
@{
    // Pain points + matching inline icon glyph; copy fixed by the customer brief (claim-safe).
    var pains = new (string Text, string Tone, string Path)[]
    {
        ("You study regularly but your score does not improve.", "terra",
            "M3 3v18h18M7 14l4-4 3 3 5-6"),
        ("You are unsure what IELTS examiners actually expect.", "teal",
            "M12 17h.01M9.1 9a3 3 0 1 1 4.4 2.6c-.9.5-1.5 1.1-1.5 2.4"),
        ("You struggle to organize ideas in Writing Task 1 and Task 2.", "terra",
            "M4 6h16M4 12h16M4 18h10"),
        ("You lack confidence in the Speaking test.", "teal",
            "M12 15a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3zM5 11a7 7 0 0 0 14 0M12 18v3"),
        ("You feel overwhelmed by too much IELTS advice online.", "terra",
            "M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0M8 9l8 6M16 9l-8 6"),
        ("You need a clear study plan and practical guidance.", "teal",
            "M9 11l3 3 8-8M21 12a9 9 0 1 1-6.2-8.5"),
    };
    string Tone(string t) => t == "terra" ? "text-terra-500" : "text-teal-600";
    string ToneBg(string t) => t == "terra" ? "bg-terra-400/12" : "bg-teal-50";
}
<!-- ============== PROBLEM / PAIN POINTS ============== -->
<section id="problem" class="py-20 md:py-28" aria-labelledby="problem-heading">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <!-- Section header -->
    <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— The challenge</div>
    <h2 id="problem-heading" class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02] max-w-[18ch]">
      Why many IELTS candidates stay stuck below Band&nbsp;7
    </h2>
    <p class="mt-5 text-[16.5px] text-ink/70 leading-relaxed max-w-[620px]">
      Preparing for IELTS can feel confusing when you are studying hard but still not seeing your score
      improve. IELTS Band 7 Plus™ is designed to give you a clearer path, practical strategies, and expert
      guidance so you know exactly what to improve next.
    </p>

    <!-- Pain-point cards -->
    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
@foreach (var p in pains)
{
      <div class="bg-card border hairline rounded-2xl p-6 lift">
        <div class="flex items-start gap-4">
          <span class="shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-xl @ToneBg(p.Tone)">
            <svg class="w-5 h-5 @Tone(p.Tone)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="@p.Path"/></svg>
          </span>
          <h3 class="text-[15.5px] font-semibold text-ink/85 leading-snug">@p.Text</h3>
        </div>
      </div>
}
    </div>

    <!-- Solution transition band -->
    <div class="relative mt-12 bg-teal-700 text-parch rounded-2xl p-8 md:p-10 overflow-hidden">
      <div class="absolute inset-0 grain opacity-40 pointer-events-none"></div>
      <div class="relative grid lg:grid-cols-12 gap-6 lg:gap-10 items-center">
        <div class="lg:col-span-7">
          <div class="font-mono uppercase tracking-[0.18em] text-[11px] text-parch/70">— The way forward</div>
          <p class="mt-3 font-display text-[24px] md:text-[30px] font-medium leading-[1.18] text-parch">
            IELTS Band 7 Plus™ gives learners structured resources, proven strategies, and personalized
            feedback so they know exactly what to improve next.
          </p>
        </div>
        <div class="lg:col-span-5 flex flex-col sm:flex-row lg:flex-col gap-3 lg:items-stretch">
          <a href="#formula" class="group inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-parch text-teal-800 font-semibold hover:bg-white transition">
            Explore the Band 7+ Formula
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="#services" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full border border-parch/40 text-parch font-semibold hover:bg-parch/10 transition">
            See the services
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
