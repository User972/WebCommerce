@model SirJoshua.Web.ViewModels.HomeViewModel
<!-- ============== SUCCESS STORIES (claim-safe) ============== -->
<section id="success" class="py-20 md:py-28 bg-paper/40 border-y hairline" aria-labelledby="success-heading">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <!-- Heading -->
    <div class="max-w-[720px]">
      <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— Success stories</div>
      <h2 id="success-heading" class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02]">What students are working toward</h2>
      <p class="mt-4 text-[16.5px] text-ink/70 leading-relaxed">
        These describe the outcomes learners aim for with IELTS Band 7 Plus™ — not individual testimonials.
        We’ll feature verified student results here once they’re approved for sharing.
      </p>
    </div>

    <!-- Outcome cards -->
    <div class="mt-10 md:mt-12 grid md:grid-cols-3 gap-5 md:gap-6">
@foreach (var o in SiteContent.SuccessOutcomes)
{
      <div class="bg-card border hairline rounded-2xl p-6 lift">
        <div class="w-11 h-11 rounded-xl bg-teal-50 text-teal-600 flex items-center justify-center">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/></svg>
        </div>
        <h3 class="mt-4 font-display text-[20px] font-semibold leading-tight">@o.Title</h3>
        <p class="mt-2 text-ink/65 leading-relaxed">@o.Body</p>
      </div>
}
    </div>

    <!-- Disclaimer -->
    <p class="mt-6 text-[12.5px] text-ink/50">
      Results vary based on starting level, study consistency, and test readiness.
    </p>
  </div>
</section>
