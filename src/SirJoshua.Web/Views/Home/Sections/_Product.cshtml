@model SirJoshua.Web.ViewModels.HomeViewModel
@{
    var f = SiteContent.Flagship;
    var ebook = Model.Flagship; // catalog row that backs PayPal pricing (may be null)
    var inCatalog = ebook is not null;
}
<!-- ============== FEATURED PRODUCT ============== -->
<section id="formula" class="py-20 md:py-28 bg-paper/40 border-y hairline" aria-labelledby="formula-heading">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-start">
      <!-- Left: outcome-driven copy -->
      <div class="lg:col-span-7">
        <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— The Band 7+ Formula</div>
        <h2 id="formula-heading" class="mt-3 font-display text-[34px] md:text-[46px] font-medium leading-[1.04]">@f.Name</h2>
        <p class="mt-4 text-[16.5px] text-ink/70 leading-relaxed max-w-[620px]">@f.Description</p>

        <h3 class="mt-8 font-display text-[19px] font-semibold">What you’ll learn</h3>
        <div class="mt-4 grid sm:grid-cols-2 gap-x-6 gap-y-3">
@foreach (var o in f.LearningOutcomes)
{
          <div class="flex items-start gap-2.5 text-[14.5px] text-ink/80">
            <svg class="w-5 h-5 mt-0.5 text-teal-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
            <span>@o</span>
          </div>
}
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-[13px] text-ink/60">
          <span class="inline-flex items-center gap-1.5"><svg class="w-4 h-4 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>Digital guide · PDF</span>
          <span class="inline-flex items-center gap-1.5"><svg class="w-4 h-4 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>Delivered to your email</span>
          <a href="@f.Route" class="inline-flex items-center gap-1 text-teal-700 font-semibold hover:gap-2 transition-all">Full product details →</a>
        </div>
      </div>

      <!-- Right: pricing card -->
      <div class="lg:col-span-5">
@if (inCatalog)
{
        <div class="relative bg-card border hairline rounded-[20px] p-6 md:p-7 shadow-[0_30px_80px_-40px_rgba(15,61,62,.35)]"
             data-product data-id="@ebook!.Id" data-title="@ebook.Title" data-author="@ebook.Author" data-price="@ebook.PriceIdr" data-cat="@ebook.Category" data-cover="@ebook.Cover">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-terra-50 text-terra-700 text-[11.5px] font-semibold" style="background:#FBE7DD">Launch offer</div>
          <div class="mt-4 flex items-end gap-3">
            <span class="price-launch text-[42px] text-ink leading-none">@Money.Rp(f.LaunchPriceIdr)</span>
            <span class="text-[16px] text-ink/45 price-strike mb-1.5">@Money.Rp(f.RegularPriceIdr)</span>
          </div>
          <p class="mt-1.5 text-[13px] text-terra-600 font-semibold">Save @Money.Rp(f.SavingsIdr) at the launch price.</p>

          <ul class="mt-5 space-y-2.5 text-[14px] text-ink/80">
@foreach (var inc in f.Inclusions.Take(4))
{
            <li class="flex items-start gap-2.5"><svg class="w-[18px] h-[18px] mt-0.5 text-teal-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>@inc</li>
}
          </ul>

          <div class="mt-6 flex flex-col gap-2.5">
            <button type="button" class="add-cart inline-flex items-center justify-center gap-2 w-full px-6 py-3.5 rounded-full bg-terra-500 text-white font-semibold hover:bg-terra-600 transition shadow-[0_10px_24px_-12px_rgba(217,119,87,.85)]" data-id="@ebook.Id">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg>Get the Band 7+ Formula
            </button>
            <button type="button" data-enquiry="product" data-interest="Band 7+ Formula" data-item="@f.Id" class="btn-ghost w-full">
              Request payment link
            </button>
          </div>
          <p class="mt-3 text-center text-[11.5px] text-ink/50">Start writing better responses — instant download after payment.</p>

          <div class="mt-5 pt-5 border-t hairline">
            <div class="font-mono uppercase tracking-[0.16em] text-[10px] text-ink/45 mb-2.5">Pay with</div>
            <div class="flex flex-wrap gap-1.5">
@foreach (var pm in SiteContent.PaymentMethods)
{
              <span class="px-2.5 py-1 rounded-md border hairline bg-surface text-[11.5px] font-semibold text-ink/70">@pm.Name</span>
}
            </div>
          </div>
        </div>
}
else
{
        <div class="relative bg-card border hairline rounded-[20px] p-6 md:p-7 shadow-[0_30px_80px_-40px_rgba(15,61,62,.35)]">
          <div class="mt-1 flex items-end gap-3">
            <span class="price-launch text-[42px] text-ink leading-none">@Money.Rp(f.LaunchPriceIdr)</span>
            <span class="text-[16px] text-ink/45 price-strike mb-1.5">@Money.Rp(f.RegularPriceIdr)</span>
          </div>
          <p class="mt-1.5 text-[13px] text-terra-600 font-semibold">Launch price · save @Money.Rp(f.SavingsIdr).</p>
          <button type="button" data-enquiry="product" data-interest="Band 7+ Formula" data-item="@f.Id" class="btn-primary w-full mt-6">
            Get the Band 7+ Formula
          </button>
          <p class="mt-3 text-center text-[11.5px] text-ink/50">We’ll send payment &amp; access instructions.</p>
        </div>
}
      </div>
    </div>
  </div>
</section>
