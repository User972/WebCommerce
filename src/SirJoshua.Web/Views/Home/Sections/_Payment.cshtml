@model SirJoshua.Web.ViewModels.HomeViewModel
<!-- ============== PAYMENT OPTIONS ============== -->
<section id="payment" class="py-20 md:py-28 bg-paper/40 border-y hairline" aria-labelledby="payment-heading">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="max-w-[760px]">
      <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— Payment options</div>
      <h2 id="payment-heading" class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02]">Simple, flexible payment</h2>
      <p class="mt-4 text-[16.5px] text-ink/70 leading-relaxed">
        Choose the method that suits you. PayPal supports instant checkout for digital products; for every
        other method we send a secure payment link after you request your product or service. We never
        collect or store card details on this site.
      </p>
    </div>

@if (!Model.PayPalEnabled)
{
    <div class="mt-6 inline-flex items-start gap-2.5 px-4 py-3 rounded-xl bg-card border hairline text-[13.5px] text-ink/70 max-w-[640px]">
      <svg class="w-4 h-4 mt-0.5 text-terra-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <span>Instant PayPal checkout is being finalized — all orders are currently confirmed via secure payment link.</span>
    </div>
}

    <!-- Accepted methods -->
    <h3 class="sr-only">Accepted payment methods</h3>
    <ul class="mt-8 flex flex-wrap gap-2.5">
@foreach (var pm in SiteContent.PaymentMethods)
{
      <li class="pay-chip@(pm.SupportsCheckout ? " is-live" : "")" title="@pm.Instructions">
        <span class="dot" aria-hidden="true"></span>
        <span class="text-ink">@pm.Name</span>
@if (pm.SupportsCheckout)
{
        <span class="font-mono uppercase tracking-[0.12em] text-[9.5px] text-teal-700 bg-teal-50 rounded px-1.5 py-0.5">Instant</span>
}
else
{
        <span class="font-mono uppercase tracking-[0.12em] text-[9.5px] text-ink/45 bg-paper rounded px-1.5 py-0.5">Pay by request</span>
}
      </li>
}
    </ul>

    <!-- Per-method instructions -->
    <dl class="mt-7 grid sm:grid-cols-2 gap-x-8 gap-y-3 max-w-[860px]">
@foreach (var pm in SiteContent.PaymentMethods)
{
      <div class="flex items-start gap-2.5 text-[13.5px]">
        <svg class="w-4 h-4 mt-0.5 text-teal-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
        <div>
          <dt class="font-semibold text-ink/85">@pm.Name</dt>
          <dd class="text-ink/60 leading-snug">@pm.Instructions</dd>
        </div>
      </div>
}
    </dl>

    <!-- Reassurance points -->
    <div class="mt-12 grid sm:grid-cols-3 gap-4">
      <div class="bg-card border hairline rounded-2xl p-6 lift">
        <div class="w-10 h-10 rounded-xl bg-teal-50 text-teal-700 flex items-center justify-center">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3 class="mt-4 font-display text-[18px] font-semibold leading-tight">Secure payment links</h3>
        <p class="mt-1.5 text-[13.5px] text-ink/60 leading-snug">Every non-instant method is settled through a secure link we send directly to you.</p>
      </div>
      <div class="bg-card border hairline rounded-2xl p-6 lift">
        <div class="w-10 h-10 rounded-xl bg-teal-50 text-teal-700 flex items-center justify-center">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <h3 class="mt-4 font-display text-[18px] font-semibold leading-tight">No card details stored on this site</h3>
        <p class="mt-1.5 text-[13.5px] text-ink/60 leading-snug">We never collect or store your card information here — payments are handled by the provider.</p>
      </div>
      <div class="bg-card border hairline rounded-2xl p-6 lift">
        <div class="w-10 h-10 rounded-xl bg-teal-50 text-teal-700 flex items-center justify-center">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        </div>
        <h3 class="mt-4 font-display text-[18px] font-semibold leading-tight">Instructions sent to your email</h3>
        <p class="mt-1.5 text-[13.5px] text-ink/60 leading-snug">After you request a product or service, payment and access instructions arrive in your inbox.</p>
      </div>
    </div>
  </div>
</section>
