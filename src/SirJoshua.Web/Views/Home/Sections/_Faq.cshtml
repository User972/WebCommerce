@model SirJoshua.Web.ViewModels.HomeViewModel
<!-- ============== FAQ ============== -->
<section id="faq" class="py-20 md:py-28" aria-labelledby="faq-heading">
  <div class="max-w-[1080px] mx-auto px-5 md:px-8">
    <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— FAQ</div>
    <h2 id="faq-heading" class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02]">Questions, answered.</h2>

    <div class="mt-10 divide-y hairline border-y hairline">
@{
    var i = 0;
}
@foreach (var item in SiteContent.GeneralFaq)
{
      <details class="group py-5"@(i == 0 ? " open" : "")>
        <summary class="flex items-center justify-between gap-6">
          <span class="font-display text-[20px] md:text-[22px] font-semibold leading-snug pr-6">@item.Question</span>
          <span class="faq-icon shrink-0 w-9 h-9 rounded-full border hairline flex items-center justify-center text-terra-600 text-xl leading-none">+</span>
        </summary>
        <p class="mt-3 text-[15.5px] text-ink/70 leading-relaxed max-w-[760px]">@item.Answer</p>
      </details>
      i++;
}
    </div>

    <p class="mt-8 text-[15px] text-ink/70">
      Still have a question?
      <a href="https://wa.me/@SiteContent.WhatsAppNumber" target="_blank" rel="noopener" class="text-teal-700 font-semibold underline-hover">Message us on WhatsApp</a>
      or <a href="#contact" class="text-teal-700 font-semibold underline-hover">send an enquiry →</a>
    </p>
  </div>
</section>
