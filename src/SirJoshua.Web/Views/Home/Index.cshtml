<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          ink:      'rgb(var(--c-ink) / <alpha-value>)',
          surface:  'rgb(var(--c-surface) / <alpha-value>)',
          card:     'rgb(var(--c-card) / <alpha-value>)',
          paper:    'rgb(var(--c-paper) / <alpha-value>)',
          parch:    'rgb(var(--c-parch) / <alpha-value>)',
          cream:    'rgb(var(--c-surface) / <alpha-value>)',
          line:     'rgb(var(--c-line) / <alpha-value>)',
          teal:     { 50:'#E8F0EF', 100:'#C9DAD8', 500:'#1A5C5C', 600:'#0F3D3E', 700:'#0A2C2D', 800:'#06201F' },
          terra:    { 400:'#E89679', 500:'#D97757', 600:'#C0603F', 700:'#9E4A2D' },
          gold:     '#C8A24B',
        },
        fontFamily: {
          serif: ['Fraunces', 'ui-serif', 'Georgia', 'serif'],
          sans:  ['"Plus Jakarta Sans"', 'ui-sans-serif', 'system-ui', 'sans-serif'],
          mono:  ['"JetBrains Mono"', 'ui-monospace', 'monospace'],
        },
      }
    }
  }
</script>
<style>
  :root, [data-theme="light"] {
    --c-surface: 250 246 238;   /* cream page */
    --c-card:    255 255 255;   /* card / white */
    --c-paper:   243 236 221;   /* subtle band */
    --c-ink:      21  32  31;   /* primary text */
    --c-parch:   250 246 238;   /* fixed light — text/elements on teal panels */
    --c-line:    228 220 200;   /* hairline */
    color-scheme: light;
  }
  [data-theme="dark"] {
    --c-surface:  12  17  17;   /* near-black slate-teal page */
    --c-card:     22  30  29;   /* elevated card */
    --c-paper:    29  39  38;   /* subtle band */
    --c-ink:     233 230 221;   /* light parchment text */
    --c-parch:   250 246 238;   /* stays light on teal panels */
    --c-line:     43  55  54;   /* hairline */
    color-scheme: dark;
  }
  html, body { background: rgb(var(--c-surface)); color: rgb(var(--c-ink)); font-family: 'Plus Jakarta Sans', system-ui, sans-serif; transition: background-color .35s ease, color .35s ease; }
  .font-display { font-family: 'Fraunces', Georgia, serif; font-optical-sizing: auto; font-variation-settings: "SOFT" 30, "WONK" 0; letter-spacing: -0.02em; }
  .grain { background-image: radial-gradient(rgba(15,61,62,0.05) 1px, transparent 1px); background-size: 3px 3px; }
  .hairline { border-color: rgb(var(--c-line)); }
  .underline-hover { background-image: linear-gradient(currentColor, currentColor); background-size: 0% 1px; background-repeat: no-repeat; background-position: 0 100%; transition: background-size .3s ease; }
  .underline-hover:hover { background-size: 100% 1px; }
  .tick { width:12px; height:12px; }
  .stripe-placeholder {
    background-image: repeating-linear-gradient(135deg, #E4DCC8 0 8px, transparent 8px 16px);
    background-color: #F3ECDD;
  }
  details > summary { list-style: none; cursor: pointer; }
  details > summary::-webkit-details-marker { display: none; }
  details[open] .faq-icon { transform: rotate(45deg); }
  .faq-icon { transition: transform .25s ease; }
  .pulse-wa::before {
    content:''; position:absolute; inset:0; border-radius:9999px; background:#25D366; opacity:.55;
    animation: wapulse 2.4s ease-out 3;
  }
  @@keyframes wapulse { 0%{transform:scale(1);opacity:.55} 100%{transform:scale(1.8);opacity:0} }
  /* form focus */
  input:focus, select:focus, textarea:focus { outline: none; box-shadow: 0 0 0 3px rgba(217,119,87,.25); border-color:#D97757 !important; }
  /* horizontal scroll snap for stepper on mobile */
  .snap-x-step { scroll-snap-type: x mandatory; }
  .snap-x-step > * { scroll-snap-align: start; }
  /* gentle lift */
  .lift { transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease; }
  .lift:hover { transform: translateY(-2px); border-color:#0F3D3E; box-shadow: 0 12px 30px -16px rgba(15,61,62,.25); }
  /* hide scrollbar */
  .no-bar::-webkit-scrollbar{display:none} .no-bar{scrollbar-width:none}

  /* ===== DARK THEME OVERRIDES ===== */
  [data-theme="dark"] .grain { background-image: radial-gradient(rgba(255,255,255,0.035) 1px, transparent 1px); }
  [data-theme="dark"] .stripe-placeholder { background-color:#1b2524; background-image: repeating-linear-gradient(135deg, rgba(255,255,255,.05) 0 8px, transparent 8px 16px); }
  [data-theme="dark"] .bg-teal-50 { background-color: rgba(111,183,174,.14) !important; }
  [data-theme="dark"] .bg-teal-50\/60 { background-color: rgba(111,183,174,.05) !important; }
  [data-theme="dark"] .text-teal-700, [data-theme="dark"] .text-teal-600 { color:#6FB7AE !important; }
  [data-theme="dark"] .lift:hover { border-color:#6FB7AE; box-shadow: 0 14px 34px -18px rgba(0,0,0,.65); }
  /* card elevation in dark for the cream-on-teal cards that became surface */
  [data-theme="dark"] input, [data-theme="dark"] select { color: rgb(var(--c-ink)); }
  [data-theme="dark"] select option { background:#1b2524; color:#E9E6DD; }

  /* ===== EBOOK STORE ===== */
  .chip { transition: background-color .2s ease, color .2s ease, border-color .2s ease; }
  .ebook-card .ebook-cover { transition: transform .3s ease; }
  .ebook-card:hover .ebook-cover { transform: translateY(-4px) rotate(-.4deg); }
  .ebook-cover { position:relative; aspect-ratio:3/4; border-radius:12px; overflow:hidden; display:flex; box-shadow:0 16px 36px -20px rgba(0,0,0,.55); }
  .ebook-cover .inner { position:relative; z-index:2; display:flex; flex-direction:column; height:100%; width:100%; padding:20px 18px 18px 24px; }
  .ebook-cover .spine { position:absolute; left:0; top:0; bottom:0; width:11px; background:linear-gradient(90deg, rgba(0,0,0,.32), rgba(0,0,0,0)); z-index:3; }
  .ebook-cover .frame { position:absolute; inset:12px 12px 12px 18px; border:1px solid currentColor; opacity:.20; border-radius:5px; z-index:1; }
  .ebook-cover::after { content:''; position:absolute; inset:0; z-index:1; background:linear-gradient(180deg, rgba(255,255,255,.08), transparent 40%, rgba(0,0,0,.30)); pointer-events:none; }
  .ebook-cover .imprint { font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:.24em; text-transform:uppercase; opacity:.7; }
  .ebook-cover .series { font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:.16em; text-transform:uppercase; opacity:.78; }
  .ebook-cover .title { font-family:'Fraunces',serif; font-weight:600; letter-spacing:-0.02em; line-height:1.02; font-size:23px; margin-top:7px; text-wrap:balance; }
  .ebook-cover .by { font-size:11.5px; opacity:.82; margin-top:9px; }
  .ebook-cover .rule { height:1px; background:currentColor; opacity:.28; margin-bottom:9px; }
  .cover-teal { background:#0F3D3E; color:#FAF6EE; }
  .cover-deep { background:#0A2C2D; color:#FAF6EE; }
  .cover-terra{ background:#BC5E3E; color:#FBEFE7; }
  .cover-ink  { background:#1C2625; color:#F1EAD9; }
  .cover-gold { background:#C8A24B; color:#241D08; }
  .cover-sand { background:#E7DCC4; color:#173130; }
  .cart-thumb { width:46px; height:61px; border-radius:6px; box-shadow:0 6px 14px -8px rgba(0,0,0,.5); flex:none; aspect-ratio:auto; }
  .cart-thumb .frame { inset:5px; }
  .qty-btn { width:26px; height:26px; display:flex; align-items:center; justify-content:center; border-radius:7px; font-size:15px; line-height:1; }

  /* ===== CART DRAWER ===== */
  .drawer-overlay { position:fixed; inset:0; background:rgba(6,10,10,.55); backdrop-filter:blur(2px); opacity:0; visibility:hidden; transition:opacity .3s ease; z-index:60; }
  .drawer-overlay.open { opacity:1; visibility:visible; }
  .cart-drawer { position:fixed; top:0; right:0; height:100%; width:min(440px,100vw); background:rgb(var(--c-surface)); border-left:1px solid rgb(var(--c-line)); transform:translateX(100%); transition:transform .38s cubic-bezier(.4,0,.2,1); z-index:61; display:flex; flex-direction:column; }
  .cart-drawer.open { transform:translateX(0); }
  .cart-badge { position:absolute; top:-5px; right:-5px; min-width:18px; height:18px; padding:0 4px; border-radius:9px; background:#D97757; color:#fff; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center; line-height:1; }
  .cart-badge.hide { display:none; }
  .cartbtn-bump { animation: cartbump .4s ease; }
  @@keyframes cartbump { 0%,100%{transform:scale(1)} 35%{transform:scale(1.18)} }
  .pay-opt:has(input:checked) { border-color:#0F3D3E; background:rgb(var(--c-paper)); }
  [data-theme="dark"] .pay-opt:has(input:checked) { border-color:#6FB7AE; }

  /* ===== THEME TOGGLE ===== */
  #themeToggle .icon-sun { display:none; }
  #themeToggle .icon-moon { display:block; }
  [data-theme="dark"] #themeToggle .icon-sun { display:block; }
  [data-theme="dark"] #themeToggle .icon-moon { display:none; }
</style>
@if (Model.PayPalEnabled)
{
