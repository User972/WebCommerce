  };
  var RULES = [
    { re:/^(\d+) item$/, to:function(m){ return m[1]+(m[1]==='1'?' item':' items'); } },
    { re:/^Bayar (Rp .+)$/, to:'Pay $1' },
    { re:/^Diskon \((\S+)\)$/, to:'Discount ($1)' }
  ];

  var LANG='id';
  var origMap = new WeakMap();
  function parts(s){ return s.match(/^(\s*)([\s\S]*?)(\s*)$/); }
  function lookup(core){
    if(Object.prototype.hasOwnProperty.call(DICT, core)) return DICT[core];
    for(var i=0;i<RULES.length;i++){ var mm=core.match(RULES[i].re); if(mm){ return typeof RULES[i].to==='function' ? RULES[i].to(mm) : core.replace(RULES[i].re, RULES[i].to); } }
    return null;
  }
  function textNodes(root){
    if(root.nodeType===3) return [root];
    if(root.nodeType!==1) return [];
    var out=[];
    var w=document.createTreeWalker(root, NodeFilter.SHOW_TEXT, { acceptNode:function(n){
      if(!n.nodeValue || !n.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
      var p=n.parentNode; if(!p) return NodeFilter.FILTER_REJECT;
      var nm=p.nodeName;
      if(nm==='SCRIPT'||nm==='STYLE'||nm==='TEXTAREA') return NodeFilter.FILTER_REJECT;
      if(p.closest && p.closest('#langToggle')) return NodeFilter.FILTER_REJECT;
      return NodeFilter.FILTER_ACCEPT;
    }});
    while(w.nextNode()) out.push(w.currentNode);
    return out;
  }
  function applyText(n){
    if(!origMap.has(n)) origMap.set(n, n.nodeValue);
    var orig=origMap.get(n), m=parts(orig), out=orig;
    if(LANG==='en'){ var t=lookup(m[2]); if(t!=null) out=m[1]+t+m[3]; }
    if(n.nodeValue!==out) n.nodeValue=out;
  }
  function handlePh(el){
    if(el.__ph==null) el.__ph=el.getAttribute('placeholder');
    var t = LANG==='en' ? lookup(el.__ph) : null;
    el.setAttribute('placeholder', t!=null ? t : el.__ph);
  }
  function applyAttrs(root){
    if(root.nodeType!==1) return;
    if(root.hasAttribute('placeholder')) handlePh(root);
    root.querySelectorAll('[placeholder]').forEach(handlePh);
  }
  function applyTree(root){ textNodes(root).forEach(applyText); applyAttrs(root); }

  var cfg={subtree:true, childList:true, characterData:true};
  var mo=new MutationObserver(function(muts){
    mo.disconnect();
    muts.forEach(function(m){
      if(m.type==='characterData'){
        origMap.set(m.target, m.target.nodeValue);
        applyText(m.target);
      } else if(m.type==='childList'){
        m.addedNodes.forEach(function(nd){ applyTree(nd); });
      }
    });
    mo.takeRecords();
    mo.observe(document.body, cfg);
  });

  function setLang(lang){
    LANG=lang;
    document.documentElement.setAttribute('lang', lang);
    thumb.style.transform = lang==='id' ? 'translateX(34px)' : 'translateX(0)';
    opts.forEach(function(o){
      var on=o.getAttribute('data-lang')===lang;
      o.classList.toggle('text-teal-800', on);
      o.classList.toggle('text-parch/60', !on);
    });
    mo.disconnect();
    applyTree(document.body);
    mo.takeRecords();
    mo.observe(document.body, cfg);
    try{ localStorage.setItem(LKEY, lang); }catch(e){}
  }

  var saved;
  try{ saved=localStorage.getItem(LKEY); }catch(e){}
  setLang(saved==='en' ? 'en' : 'id');
  opts.forEach(function(o){ o.addEventListener('click', function(){ setLang(o.getAttribute('data-lang')); }); });
})();
