<section id="ebooks" class="py-20 md:py-28 bg-paper/40 border-y hairline">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="grid md:grid-cols-12 gap-8 items-end mb-10">
      <div class="md:col-span-7">
        <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-600">— Toko ebook</div>
        <h2 class="mt-3 font-display text-[40px] md:text-[52px] font-medium leading-[1.02]">Lanjutkan belajar<br/>di rumah, dengan <em class="not-italic text-terra-600">harga terjangkau</em>.</h2>
      </div>
      <p class="md:col-span-5 text-[16px] text-ink/65 leading-relaxed">
        Panduan, latihan soal, dan strategi langsung dari pengajar Sir Joshua — dikirim ke email kamu dalam format PDF &amp; EPUB, bisa dibaca di perangkat apa saja.
      </p>
    </div>

    <!-- filter chips -->
    <div class="flex flex-wrap items-center gap-2 mb-8" id="ebookFilters">
      <button data-filter="all" class="chip px-4 py-2 rounded-full text-[13px] font-semibold bg-teal-600 text-parch border border-teal-600">Semua</button>
      <button data-filter="IELTS" class="chip px-4 py-2 rounded-full text-[13px] font-semibold bg-card border hairline text-ink/70 hover:border-teal-600">IELTS</button>
      <button data-filter="TOEFL" class="chip px-4 py-2 rounded-full text-[13px] font-semibold bg-card border hairline text-ink/70 hover:border-teal-600">TOEFL</button>
      <button data-filter="PTE" class="chip px-4 py-2 rounded-full text-[13px] font-semibold bg-card border hairline text-ink/70 hover:border-teal-600">PTE</button>
      <button data-filter="Umum" class="chip px-4 py-2 rounded-full text-[13px] font-semibold bg-card border hairline text-ink/70 hover:border-teal-600">Umum</button>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
@foreach (var e in Model.Ebooks.Where(x => !x.IsBundle))
{
      <article class="ebook-card lift bg-card border hairline rounded-2xl p-4 flex flex-col" data-product data-id="@e.Id" data-title="@e.Title" data-author="@e.Author" data-price="@e.PriceIdr" data-cat="@e.Category" data-cover="@e.Cover">
        <div class="relative">
@if (e.Badge == "Terlaris")
{
          <span class="absolute z-10 top-3 right-3 px-2 py-0.5 rounded-full bg-terra-500 text-white text-[10.5px] font-semibold tracking-wide">Terlaris</span>
}
else if (e.Badge == "Baru")
{
          <span class="absolute z-10 top-3 right-3 px-2 py-0.5 rounded-full bg-emerald-500 text-white text-[10.5px] font-semibold tracking-wide">Baru</span>
}
          <div class="ebook-cover cover-@e.Cover"><span class="spine"></span><span class="frame"></span>
            <div class="inner"><span class="imprint">Sir Joshua Press</span><div class="flex-1"></div><div class="rule"></div><span class="series">@e.Series</span><div class="title">@e.Title</div><span class="by">@e.Author</span></div>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-2 text-[12px]"><span class="px-2 py-0.5 rounded-full bg-teal-50 text-teal-700 font-medium">@e.Category</span><span class="text-ink/55">@e.Meta</span></div>
        <h3 class="mt-2 font-display text-[20px] font-semibold leading-tight">@e.Title</h3>
        <p class="mt-1 text-[13.5px] text-ink/60 leading-snug">@e.Description</p>
        <div class="mt-2.5 flex items-center gap-1.5 text-[12.5px] text-ink/65"><svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="#D97757"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21 7 14.14l-5-4.87 7.1-1.01z"/></svg><span class="font-semibold text-ink/80">@e.Rating.ToString("0.0", inv)</span><span class="text-ink/40">(@e.ReviewCount ulasan)</span></div>
        <div class="mt-auto pt-4 flex items-center justify-between gap-3">
          <div class="font-display text-[21px] font-semibold leading-none">@Rp(e.PriceIdr)</div>
          <button class="add-cart inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-teal-600 text-parch text-[13px] font-semibold hover:bg-teal-700 transition" data-id="@e.Id"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg>Tambah</button>
        </div>
      </article>
}
    </div>

    <p id="ebookEmpty" class="hidden text-center text-ink/55 py-14 text-[15px]">Belum ada ebook di kategori ini.</p>

@{ var bundle = Model.Ebooks.FirstOrDefault(x => x.IsBundle); }
@if (bundle != null)
{
    <div class="mt-5 rounded-2xl bg-teal-700 text-parch p-6 md:p-9 grid md:grid-cols-12 gap-6 items-center relative overflow-hidden" data-product data-id="@bundle.Id" data-title="@bundle.Title" data-author="@bundle.Author" data-price="@bundle.PriceIdr" data-cat="@bundle.Category" data-cover="@bundle.Cover">
      <div class="absolute inset-0 grain opacity-15"></div>
      <div class="md:col-span-8 relative">
        <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-400">- Paket hemat</div>
        <h3 class="mt-2 font-display text-[30px] md:text-[38px] font-medium leading-[1.04]">@bundle.Title - 6 ebook sekaligus.</h3>
        <p class="mt-3 text-[14.5px] text-parch/75 max-w-[560px]">@bundle.Description</p>
        <div class="mt-5 flex flex-wrap gap-1.5 text-[11.5px]">
@foreach (var name in new[] { "Writing Playbook", "Speaking Without Fear", "TOEFL Integrated", "PTE Rapid Score", "Vocabulary Builder", "Reading Speed" })
{
          <span class="px-2.5 py-1 rounded-full bg-parch/10 border border-parch/15">@name</span>
}
        </div>
      </div>
      <div class="md:col-span-4 md:text-right relative">
@if (bundle.CompareAtIdr.HasValue)
{
        <div class="text-[13px] text-parch/55 line-through">@Rp(bundle.CompareAtIdr.Value)</div>
}
        <div class="font-display text-[44px] font-semibold leading-none mt-1">@Rp(bundle.PriceIdr)</div>
        <button class="add-cart mt-5 w-full md:w-auto inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-terra-500 text-white font-semibold hover:bg-terra-600 transition" data-id="@bundle.Id"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg>Tambah paket</button>
      </div>
    </div>
}
  </div>
</section>

