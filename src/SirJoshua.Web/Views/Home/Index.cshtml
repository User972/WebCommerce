@model SirJoshua.Web.ViewModels.HomeViewModel
@using System.Globalization
@{
    Layout = null;
    var inv = CultureInfo.InvariantCulture;
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var desc = "Prepare effectively for IELTS with practical resources, proven strategies, writing feedback, speaking assessment, and personalized guidance designed to help you reach Band 7+.";
}
<!doctype html>
<html lang="en">
<head>
<script>(function(){try{var t=localStorage.getItem('check-theme');if(t!=='light'&&t!=='dark'){t=window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';}document.documentElement.setAttribute('data-theme',t);}catch(e){document.documentElement.setAttribute('data-theme','light');}})();</script>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>IELTS Band 7 Plus™ | Achieve Your IELTS Target Score with Confidence</title>
<meta name="description" content="@desc" />
<meta name="keywords" content="IELTS Band 7, IELTS Writing Mastery, IELTS Writing Feedback, IELTS Speaking Assessment, IELTS Strategy Consultation, IELTS preparation, Band 7+ Formula" />
<link rel="canonical" href="@baseUrl/" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="@SiteContent.FooterBrand" />
<meta property="og:title" content="IELTS Band 7 Plus™ | Achieve Your IELTS Target Score with Confidence" />
<meta property="og:description" content="@desc" />
<meta property="og:url" content="@baseUrl/" />
<meta property="og:image" content="@baseUrl/uploads/sir-joshua-logo.png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="IELTS Band 7 Plus™ | Achieve Your IELTS Target Score with Confidence" />
<meta name="twitter:description" content="@desc" />
<script src="https://cdn.jsdelivr.net/npm/tailwindcss-cdn@@3.4.10/tailwindcss.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@@9..144,400;9..144,500;9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@@400;500;600;700&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/b7plus.css" asp-append-version="true" />
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          ink:      'rgb(var(--c-ink) / <alpha-value>)',
          surface:  'rgb(var(--c-surface) / <alpha-value>)',
          card:     'rgb(var(--c-card) / <alpha-value>)',
          paper:    'rgb(var(--c-paper) / <alpha-value>)',
          parch:    'rgb(var(--c-parch) / <alpha-value>)',
          cream:    'rgb(var(--c-surface) / <alpha-value>)',
          line:     'rgb(var(--c-line) / <alpha-value>)',
          teal:     { 50:'#E8F0EF', 100:'#C9DAD8', 500:'#1A5C5C', 600:'#0F3D3E', 700:'#0A2C2D', 800:'#06201F' },
          terra:    { 400:'#E89679', 500:'#D97757', 600:'#C0603F', 700:'#9E4A2D' },
          gold:     '#C8A24B',
        },
        fontFamily: {
          serif: ['Fraunces', 'ui-serif', 'Georgia', 'serif'],
          sans:  ['"Plus Jakarta Sans"', 'ui-sans-serif', 'system-ui', 'sans-serif'],
          mono:  ['"JetBrains Mono"', 'ui-monospace', 'monospace'],
        },
      }
    }
  }
</script>
<script type="application/ld+json">@Html.Raw(StructuredData.HomeJsonLd(baseUrl))</script>
@if (Model.PayPalEnabled)
{
    <script src="https://www.paypal.com/sdk/js?client-id=@Model.PayPalClientId&currency=@Model.PayPalCurrency&intent=capture&components=buttons&disable-funding=credit"></script>
}
<script>
  window.SJ_CONFIG = {
    paypalEnabled: @(Model.PayPalEnabled ? "true" : "false"),
    currency: '@Model.PayPalCurrency',
    idrPerUsd: @Model.IdrPerUsd.ToString("0.####", inv),
    promoCode: '@Model.PromoCode'
  };
  window.B7_CONFIG = {
    payments: [@Html.Raw(string.Join(",", SiteContent.PaymentMethods.Select(p => $"{{id:'{p.Id}',name:'{p.Name}'}}")))]
  };
</script>
</head>
<body class="antialiased pb-[76px] lg:pb-0" id="top">
@Html.AntiForgeryToken()
<a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:top-3 focus:left-3 focus:px-4 focus:py-2 focus:rounded-full focus:bg-teal-700 focus:text-parch focus:font-semibold">Skip to content</a>

<!-- ============== TOP STRIP ============== -->
<div class="hidden md:block bg-teal-700 text-parch/90 text-[13px]">
  <div class="max-w-[1280px] mx-auto px-6 py-2 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
      Designed to help you reach <span class="font-semibold text-parch">IELTS Band&nbsp;7+</span>
    </div>
    <div class="flex items-center gap-5">
      <a href="#free-checklist" class="hover:text-white underline-hover">Get the Free IELTS Checklist</a>
      <span class="text-parch/40">·</span>
      <a href="mailto:@SiteContent.ContactEmail" class="hover:text-white">@SiteContent.ContactEmail</a>
    </div>
  </div>
</div>

<!-- ============== HEADER ============== -->
<header class="sticky top-0 z-40 bg-surface/85 backdrop-blur border-b hairline">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 h-[68px] flex items-center justify-between gap-4">
    <a href="#top" class="flex items-center gap-2.5 shrink-0">
      <img src="/uploads/sir-joshua-logo.png" alt="Sir Joshua Academy logo" class="h-10 w-auto object-contain">
      <span class="leading-none">
        <span class="block font-display text-[18px] font-semibold tracking-tight">IELTS Band 7 Plus<span class="text-terra-500 align-super text-[10px]">™</span></span>
        <span class="block text-[11px] text-ink/55 mt-0.5">by Sir Joshua Academy</span>
      </span>
    </a>
    <nav class="hidden lg:flex items-center gap-6 text-[14.5px] text-ink/80" aria-label="Primary">
@foreach (var link in SiteContent.Nav.Skip(1))
{
      <a href="@link.Href" class="underline-hover whitespace-nowrap">@link.Label</a>
}
    </nav>
    <div class="flex items-center gap-2 md:gap-3">
      <button id="themeToggle" type="button" aria-label="Switch light / dark theme" title="Switch theme" class="w-10 h-10 rounded-full border hairline bg-card flex items-center justify-center text-ink/70 hover:text-ink hover:border-teal-600 transition">
        <svg class="icon-moon w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2.2M12 19.8V22M4.6 4.6l1.6 1.6M17.8 17.8l1.6 1.6M2 12h2.2M19.8 12H22M4.6 19.4l1.6-1.6M17.8 6.2l1.6-1.6"/></svg>
      </button>
      <button id="cartBtn" type="button" aria-label="Open cart" class="relative w-10 h-10 rounded-full border hairline bg-card flex items-center justify-center text-ink/70 hover:text-ink hover:border-teal-600 transition">
        <svg class="w-[19px] h-[19px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h2l.5 2.5M6 6h14.5l-1.6 8H8.1L6 6z"/><path d="M5.5 5.5 8.1 14"/><circle cx="9.5" cy="19" r="1.4"/><circle cx="17" cy="19" r="1.4"/></svg>
        <span id="cartBadge" class="cart-badge hide">0</span>
      </button>
      <a href="#formula" class="hidden lg:inline-flex px-4 py-2.5 rounded-full bg-terra-500 text-white text-[14px] font-semibold hover:bg-terra-600 transition shadow-[0_6px_18px_-8px_rgba(217,119,87,.7)] whitespace-nowrap">Get the Band 7+ Formula</a>
      <button id="menuBtn" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu" class="lg:hidden w-10 h-10 rounded-full border hairline bg-card flex items-center justify-center text-ink/70">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
  <!-- mobile menu -->
  <div id="mobileMenu" class="lg:hidden hidden border-t hairline bg-surface/95 backdrop-blur">
    <nav class="max-w-[1280px] mx-auto px-5 py-3 flex flex-col" aria-label="Mobile">
@foreach (var link in SiteContent.Nav.Skip(1))
{
      <a href="@link.Href" class="menu-link py-2.5 text-[15px] text-ink/80 border-b hairline last:border-0">@link.Label</a>
}
      <a href="#formula" class="menu-link mt-3 mb-1 px-4 py-3 rounded-full bg-terra-500 text-white text-[15px] font-semibold text-center">Get the Band 7+ Formula</a>
    </nav>
  </div>
</header>

<main id="main">
@await Html.PartialAsync("Sections/_Hero", Model)
@await Html.PartialAsync("Sections/_Problem", Model)
@await Html.PartialAsync("Sections/_Product", Model)
@await Html.PartialAsync("Sections/_Services", Model)
@await Html.PartialAsync("Sections/_FreeResource", Model)
@await Html.PartialAsync("Sections/_SuccessStories", Model)
@await Html.PartialAsync("Sections/_About", Model)
@await Html.PartialAsync("Sections/_ComingSoon", Model)
@await Html.PartialAsync("Sections/_Resources", Model)
@await Html.PartialAsync("Sections/_Payment", Model)
@await Html.PartialAsync("Sections/_Faq", Model)
@await Html.PartialAsync("Sections/_FinalCta", Model)
@await Html.PartialAsync("Sections/_Contact", Model)
</main>

<!-- ============== FOOTER ============== -->
<footer class="bg-teal-800 text-parch/80">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 py-16 grid md:grid-cols-12 gap-10">
    <div class="md:col-span-5">
      <div class="flex items-center gap-2.5">
        <img src="/uploads/sir-joshua-logo.png" alt="Sir Joshua Academy logo" class="h-12 w-auto object-contain">
        <span class="font-display text-[19px] font-semibold tracking-tight text-parch leading-none">IELTS Band 7 Plus<span class="text-terra-400">™</span></span>
      </div>
      <p class="mt-5 text-[14px] leading-relaxed max-w-[340px] text-parch/65">
        IELTS Band 7 Plus™ helps students, professionals and future international applicants reach their target IELTS score through practical resources, proven strategies and personalized guidance.
      </p>
      <div class="mt-6 flex items-center gap-3">
        <a href="https://wa.me/@SiteContent.WhatsAppNumber" target="_blank" rel="noopener" aria-label="WhatsApp" class="w-9 h-9 rounded-full border border-parch/20 flex items-center justify-center hover:bg-parch/10 transition text-parch/70 hover:text-parch">
          <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.95 7.95 0 0 0-6.9 11.93L4 20l4.18-1.1a7.93 7.93 0 0 0 3.86 1h.01c4.39 0 7.96-3.57 7.96-7.96 0-2.13-.83-4.13-2.34-5.62zM12.05 18.5h-.01a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.49.65.66-2.42-.16-.25a6.6 6.6 0 0 1-1.01-3.5c0-3.65 2.97-6.62 6.62-6.62 1.77 0 3.43.69 4.68 1.94a6.59 6.59 0 0 1 1.94 4.68c0 3.65-2.97 6.62-6.63 6.62z"/></svg>
        </a>
        <a href="mailto:@SiteContent.ContactEmail" aria-label="Email" class="w-9 h-9 rounded-full border border-parch/20 flex items-center justify-center hover:bg-parch/10 transition text-parch/70 hover:text-parch">
          <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        </a>
      </div>
    </div>

    <div class="md:col-span-4">
      <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-400 mb-4">Explore</div>
      <ul class="text-[14px] grid grid-cols-2 gap-x-4 gap-y-2.5">
@foreach (var link in SiteContent.Nav)
{
        <li><a href="@link.Href" class="hover:text-parch">@link.Label</a></li>
}
        <li><a href="@SiteContent.Flagship.Route" class="hover:text-parch">Product details</a></li>
      </ul>
    </div>

    <div class="md:col-span-3">
      <div class="font-mono uppercase tracking-[0.18em] text-[11.5px] text-terra-400 mb-4">Get in touch</div>
      <ul class="space-y-2.5 text-[14px]">
        <li><a href="https://wa.me/@SiteContent.WhatsAppNumber" target="_blank" rel="noopener" class="hover:text-parch">WhatsApp us</a></li>
        <li><a href="mailto:@SiteContent.ContactEmail" class="hover:text-parch">@SiteContent.ContactEmail</a></li>
        <li><a href="#contact" class="hover:text-parch">Send an enquiry</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-parch/10">
    <div class="max-w-[1280px] mx-auto px-5 md:px-8 py-5 flex flex-wrap items-center justify-between gap-3 text-[12.5px] text-parch/55">
      <div>© 2026 @SiteContent.FooterBrand. All rights reserved.</div>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-1">
        <a href="#" class="hover:text-parch">Privacy Policy</a>
        <a href="#" class="hover:text-parch">Terms</a>
      </div>
    </div>
  </div>
</footer>

<!-- ============== WHATSAPP FLOATING ============== -->
<a href="https://wa.me/@SiteContent.WhatsAppNumber" target="_blank" rel="noopener" aria-label="Chat on WhatsApp" class="fixed z-50 bottom-24 lg:bottom-6 right-5 md:right-6">
  <span class="relative inline-flex items-center justify-center w-14 h-14 rounded-full bg-[#25D366] text-white shadow-[0_10px_30px_-8px_rgba(37,211,102,.7)] pulse-wa">
    <svg class="w-7 h-7 relative" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.95 7.95 0 0 0-6.9 11.93L4 20l4.18-1.1a7.93 7.93 0 0 0 3.86 1h.01c4.39 0 7.96-3.57 7.96-7.96 0-2.13-.83-4.13-2.34-5.62zM12.05 18.5h-.01a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.49.65.66-2.42-.16-.25a6.6 6.6 0 0 1-1.01-3.5c0-3.65 2.97-6.62 6.62-6.62 1.77 0 3.43.69 4.68 1.94a6.59 6.59 0 0 1 1.94 4.68c0 3.65-2.97 6.62-6.63 6.62zm3.63-4.96c-.2-.1-1.18-.58-1.36-.65-.18-.07-.32-.1-.45.1-.13.2-.51.65-.63.78-.12.13-.23.15-.43.05-.2-.1-.84-.31-1.6-.99-.59-.52-.99-1.17-1.11-1.37-.12-.2-.01-.31.09-.41.09-.09.2-.23.3-.35.1-.12.13-.2.2-.33.07-.13.03-.25-.02-.35-.05-.1-.45-1.08-.62-1.48-.16-.39-.33-.34-.45-.34l-.38-.01c-.13 0-.34.05-.52.25-.18.2-.68.66-.68 1.6 0 .94.69 1.86.79 1.99.1.13 1.36 2.07 3.29 2.91.46.2.82.32 1.1.41.46.15.88.13 1.21.08.37-.05 1.18-.48 1.34-.95.16-.46.16-.86.12-.95-.05-.09-.18-.14-.38-.24z"/></svg>
  </span>
</a>

<!-- ============== MOBILE STICKY CTA ============== -->
<div class="lg:hidden fixed bottom-0 left-0 right-0 z-40 bg-surface/95 backdrop-blur border-t hairline px-4 py-3 flex gap-2">
  <a href="#formula" class="flex-1 px-4 py-3 rounded-full bg-terra-500 text-white font-semibold text-[14px] text-center">Get the Band 7+ Formula</a>
  <a href="#free-checklist" class="px-4 py-3 rounded-full border hairline bg-card text-teal-700 font-semibold text-[14px] text-center">Free checklist</a>
</div>

@await Html.PartialAsync("_CartDrawer")
@await Html.PartialAsync("_EnquiryModal")

<script src="~/js/funnel.js" asp-append-version="true"></script>
<script src="~/js/forms.js" asp-append-version="true"></script>
</body>
</html>
